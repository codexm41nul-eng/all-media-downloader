# ============================================
# All Media Downloader Bot — Environment Variables
# Developer: Md. Mainul Islam (MAINUL-X)
# GitHub   : https://github.com/M41NUL
# ============================================

# [REQUIRED] Your Telegram Bot token from @BotFather
BOT_TOKEN=your_telegram_bot_token_here

# [REQUIRED] Full public URL of your deployed app (no trailing slash)
WEBHOOK_URL=https://your-app-name.onrender.com

# [OPTIONAL] Your Telegram numeric user ID — grants /admin access
ADMIN_ID=123456789

# [OPTIONAL] Port — Render sets this automatically
PORT=3000

# [OPTIONAL] Path to a Netscape-format cookies.txt file for Instagram
# Export your Instagram cookies using browser extension "Get cookies.txt LOCALLY"
# Upload the file to your repo or set the path on Render disk
# INSTAGRAM_COOKIES=/app/cookies.txt
